# Immich image tag
IMMICH_VERSION=release

# Media and database storage paths
UPLOAD_LOCATION=./data/library
DB_DATA_LOCATION=./data/postgres
EXTERNAL_LIBRARY_LOCATION=./data/external

# PostgreSQL credentials used by Immich
DB_DATABASE_NAME=immich
DB_USERNAME=immich
DB_PASSWORD=change-me-immich-db-password
